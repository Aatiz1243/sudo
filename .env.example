# ── Sudo Bot — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# Discord Bot Token (required)
# Get it from: https://discord.com/developers/applications → your app → Bot
BOT_TOKEN=your_discord_bot_token_here

# Your Discord User ID (recommended)
# Enables the !approve command so you can add new responses live, without restarting.
# How to get: Settings → Advanced → Developer Mode ON → right-click your name → Copy User ID
OWNER_ID=

# Channel ID for weekly unknown command logs (optional)
# Every Sunday the bot posts the top unknown $sudo commands here for review.
LOG_CHANNEL_ID=
